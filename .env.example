# MD Javed Enterprises — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env or .env.local with real secrets

# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Use the pooled connection string for application queries
DATABASE_URL=

# Use the direct connection string for Prisma migrations (npx prisma migrate deploy)
DIRECT_URL=

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random secret for JWT signing — minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ─── Application URLs ─────────────────────────────────────────────────────────
# Production URL (no trailing slash)
APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ─── Notifications (Optional — leave blank if not used) ──────────────────────
# SMS
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# WhatsApp Business API
WHATSAPP_PROVIDER=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Email
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=

# ─── Cron Jobs (Optional) ─────────────────────────────────────────────────────
# Secret for protecting cron job endpoints
CRON_SECRET=

# ─── Error Monitoring (Optional) ──────────────────────────────────────────────
SENTRY_DSN=
